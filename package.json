{
  "name": "pi-lsp-lite",
  "version": "0.3.1",
  "description": "LSP diagnostics for pi — errors and warnings on every edit, same turn. Go, Rust, TypeScript, Python, C/C++.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcphailtom/pi-lsp-lite.git"
  },
  "homepage": "https://github.com/mcphailtom/pi-lsp-lite",
  "bugs": "https://github.com/mcphailtom/pi-lsp-lite/issues",
  "keywords": [
    "pi-package",
    "pi-extension",
    "lsp",
    "gopls",
    "rust-analyzer",
    "typescript-language-server",
    "pylsp",
    "clangd",
    "python",
    "cpp"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:integration": "INTEGRATION=1 tsx --test test/*.test.ts test/integration/*.test.ts"
  }
}
